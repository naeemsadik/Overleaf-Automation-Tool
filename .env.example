OVERLEAF_PROJECT_URL=https://www.overleaf.com/project/your-project-id
OVERLEAF_RECIPIENTS_CSV=data.csv
OVERLEAF_PROJECT_NAME=Autmatic Send
OVERLEAF_SHARE_LINK_CSV=overleaf_share_links.csv
GMAIL_COMPOSE_URL=https://mail.google.com/mail/u/0/#inbox?compose=new
GMAIL_INBOX_URL=https://mail.google.com/mail/u/0/#inbox
GMAIL_LOGIN_WAIT_SECONDS=300
EMAIL_SUBJECT_TEMPLATE=Overleaf Project Edit Access: {project_name}
EMAIL_BODY_TEMPLATE=Dear {leader_name},\n\nI hope you are doing well. I am sharing the Overleaf project {project_name} with edit access.\n\nProject details:\nProject: {project_name}\nAccess: Can edit\nLink: {link}\n\nPlease share this link with the other members of your team.\n\nPlease use the link above to open the project.\n\nRegards,\nOverleaf Automation
SELENIUM_USER_DATA_DIR=C:\Users\YourUserName\.overleaf_selenium_profile
OVERLEAF_WAIT_TIMEOUT=15
OVERLEAF_LOGIN_POLL_INTERVAL=1
OVERLEAF_POST_ACTION_WAIT_SECONDS=5